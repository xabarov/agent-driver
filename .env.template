# Provider / model
AGENT_DRIVER_PROVIDER=openrouter
AGENT_DRIVER_API_KEY=your-api-key
AGENT_DRIVER_BASE_URL=https://openrouter.ai/api/v1
AGENT_DRIVER_MODEL=qwen/qwen3.6-plus

# Provider timeouts / retries
AGENT_DRIVER_PROVIDER_TIMEOUT_S=300
AGENT_DRIVER_TIMEOUT_S=60
AGENT_DRIVER_MAX_RETRIES=3

# Tool execution
AGENT_DRIVER_TOOL_CONCURRENCY=8
AGENT_DRIVER_WEB_SEARCH_BACKEND=ddg
AGENT_DRIVER_ENABLE_PYTHON=1
AGENT_DRIVER_PYTHON_BACKEND=local
AGENT_DRIVER_PYTHON_SCIENTIFIC=1
AGENT_DRIVER_PYTHON_ALLOW_IMPORTS=statistics,math,datetime,collections,itertools,re,decimal,fractions,json,pandas,numpy,dateutil

# Runtime store: memory, sqlite, or postgres.
AGENT_DRIVER_RUNTIME_STORE_KIND=memory
AGENT_DRIVER_SQLITE_PATH=/tmp/agent_driver_runtime.sqlite
AGENT_DRIVER_POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:55432/agent_driver_live
AGENT_DRIVER_POSTGRES_SCHEMA=public
AGENT_DRIVER_POSTGRES_AUTO_CREATE_SCHEMA=1
AGENT_DRIVER_POSTGRES_CONNECT_TIMEOUT_SECONDS=5
AGENT_DRIVER_POSTGRES_APPLICATION_NAME=agent_driver_runtime

# HTTP/A2A/MCP server auth, only needed when serving remote clients.
AGENT_DRIVER_SERVER_API_KEY=

# Opt-in live checks. Keep off in CI unless the provider and Postgres are available.
AGENT_DRIVER_RUN_LIVE_TESTS=1
AGENT_DRIVER_RUN_LIVE_CLI_EVALS=0
AGENT_DRIVER_RUN_POSTGRES_TESTS=1

# Debugging
AGENT_DRIVER_DEBUG_LLM_PAYLOAD=0
